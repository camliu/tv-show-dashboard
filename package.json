{
  "name": "tv-show-dashboard",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "preview:swa": "swa start",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --project=chromium --ui",
    "test:smoke": "playwright test --project=smoke",
    "typecheck": "nuxi typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/icon": "2.2.2",
    "@nuxt/image": "2.0.0",
    "@pinia/nuxt": "0.11.3",
    "@primeuix/themes": "^2.0.3",
    "@primevue/nuxt-module": "4.5.5",
    "@tailwindcss/vite": "^4.2.4",
    "@vueuse/core": "^14.3.0",
    "date-fns": "^4.1.0",
    "isomorphic-dompurify": "^3.12.0",
    "nuxt": "^4.4.6",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@azure/static-web-apps-cli": "^2.0.9",
    "@iconify-json/lucide": "^1.2.106",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/hints": "1.1.1",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "dotenv": "^17.4.2",
    "encoding": "^0.1.13",
    "eslint": "^10.3.0",
    "h3": "1.15.11",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "msw": "^2.14.5",
    "ofetch": "1.5.1",
    "playwright-core": "^1.59.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*": [
      "pnpm lint:fix",
      "pnpm lint"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}